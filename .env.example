# ElevenCA — frontend handoff (UI-only; backend wires APIs in page files)
# Full endpoint map: open src/App.jsx and search "BACKEND INTEGRATION"

# Token storage: see src/api/auth.js (saveTokens / getAccessToken / getCsrfToken)
# Login wiring: see src/Pages/Login.jsx (BACKEND INTEGRATION block)

# Optional demo overrides (no backend required to run the UI):

# Wallet address for deposit / gas-fee QR screens (ReceiveFunds.jsx, FundGasFee.jsx)
# VITE_DEPOSIT_WALLET_ADDRESS=0xYourReceivingAddressHere

# Optional forgot-password link on the login screen (Login.jsx)
# VITE_PASSWORD_RESET_URL=https://yourbank.com/reset-password
