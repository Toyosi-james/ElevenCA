# ElevenCA — frontend-only demo (no backend required)
# Copy to .env to customize optional values.

# Where the app goes after login (default: /home)
VITE_POST_LOGIN_REDIRECT=/home

# Wallet address for deposit / gas-fee QR screens
# VITE_DEPOSIT_WALLET_ADDRESS=0xYourReceivingAddressHere

# Optional forgot-password link on the login screen
# VITE_PASSWORD_RESET_URL=https://yourbank.com/reset-password
