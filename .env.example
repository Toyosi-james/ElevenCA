# Base URL for your API (no trailing slash). Example: https://api.yourbank.com
VITE_API_BASE_URL=http://localhost:8080

# POST path for email/password sign-in (appended to VITE_API_BASE_URL)
VITE_AUTH_LOGIN_PATH=/auth/login

# Where the SPA navigates after successful sign-in (default: /home)
VITE_POST_LOGIN_REDIRECT=/home

# GET current user — default /auth/me
# VITE_AUTH_ME_PATH=/auth/me

# GET portfolio summary — default /wallet/summary
# VITE_BALANCE_PATH=/wallet/summary

# GET transaction history — default /wallet/transactions (see src/lib/api/transactions.js)
# Query: ?page=1&limit=10. If the request fails, the app shows paginated mock data for development.
# VITE_TRANSACTIONS_PATH=/wallet/transactions

# GET chart series — default /markets/flow (backend can change; normalizeFlowSeries accepts flexible JSON)
# VITE_MARKET_FLOW_PATH=/markets/flow

# Optional: full URLs opened by Deposit / Stake / Withdraw / Exchange buttons
# If unset, Deposit opens the in-app screen below with QR + copy.
# VITE_DEPOSIT_URL=https://app.example.com/deposit

# Wallet address for the in-app deposit page when GET deposit-address fails or is unset (QR encodes this string)
# VITE_DEPOSIT_WALLET_ADDRESS=0xYourReceivingAddressHere

# GET deposit receiving address — default /wallet/deposit-address (see src/lib/api/deposit.js for accepted JSON shapes)
# VITE_DEPOSIT_ADDRESS_PATH=/wallet/deposit-address
# GET gas-fee funding address — default /wallet/gas-fee-address
# VITE_FUND_GAS_FEE_ADDRESS_PATH=/wallet/gas-fee-address
# VITE_STAKE_URL=https://app.example.com/stake
# VITE_WITHDRAW_URL=https://app.example.com/withdraw
# VITE_EXCHANGE_URL=https://app.example.com/exchange
# VITE_WITHDRAW_REQUEST_PATH=/wallet/withdraw

# In-app exchange (see src/lib/api/exchange.js) — POST quote then POST execute
# VITE_EXCHANGE_QUOTE_PATH=/wallet/exchange/quote
# VITE_EXCHANGE_EXECUTE_PATH=/wallet/exchange

# Optional: profile / settings URL (header “Profile” controls)
# VITE_PROFILE_URL=https://app.example.com/profile

# Optional: forgot-password page URL for the login link (leave unset to use #)
# VITE_PASSWORD_RESET_URL=https://yourbank.com/reset-password

# GET rate-update notifications — default /wallet/notifications/rate-updates (see src/lib/api/notifications.js)
# Expected JSON: `{ items: [...] }` or `{ data: [...] }` or a raw array. Each item: id, pair, headline, body, changePct, occurredAt.
# On failure or while wiring the backend, the app falls back to mock data unless mock-only is forced below.
# VITE_NOTIFICATIONS_PATH=/wallet/notifications/rate-updates

# When true, skips the notifications GET and uses built-in simulator data only.
# VITE_NOTIFICATIONS_USE_MOCK=true
